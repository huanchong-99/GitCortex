# Reused by both install-docker.ps1 and update-docker.ps1

# Required
GITCORTEX_ENCRYPTION_KEY=your-32-char-encryption-key-here

# Optional: API token for /api routes (Docker-only variable)
GITCORTEX_DOCKER_API_TOKEN=

# AI CLI API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Server
PORT=23456
RUST_LOG=info

# Host <-> container workspace mapping
HOST_WORKSPACE_ROOT=../..
GITCORTEX_WORKSPACE_ROOT=/workspace
GITCORTEX_ALLOWED_ROOTS=/workspace,/var/lib/gitcortex

# Optional: install AI CLIs during image build (0|1)
INSTALL_AI_CLIS=0

# Optional: auto-create up to 3 starter projects after first disclaimer acceptance (0|1)
GITCORTEX_AUTO_SETUP_PROJECTS=0
